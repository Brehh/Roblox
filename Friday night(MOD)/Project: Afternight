--[[ =====================================================================
      Project: Afternight  —  AUTOPLAY  (GAME-FIRE)     placeId 13042495892
      • goodHit(note) ตี note ตรงๆ  →  Sick rating, ไม่ต้อง focus, ทุก keymode
      • heldState สำหรับ hold (นับ tick), ปล่อยตรง sustainTimes ตัวสุดท้าย
      • block missNote (โน้ตที่ตีแล้ว) → combo ไม่แตกจาก false-miss
      • setthreadidentity(2) ให้ goodHit require ได้  • mine / don't-press skip
      • receptor light (heldState) + onKeyUp รีเซ็ต  • GUI + F4 toggle
      Re-run ได้ตลอด — หา engine/ฟังก์ชันเองหลัง crash/rejoin.
===================================================================== ]]
local RunService = game:GetService("RunService")
local UIS        = game:GetService("UserInputService")
local g          = getgenv()
local getc = getconstants or debug.getconstants
local getu = getupvalues  or debug.getupvalues
local hookfn = hookfunction or debug.hookfunction
local sti = setthreadidentity or g.setthreadidentity

----------------------------------------------------- finders
local function findEngine()
  for _,o in ipairs(getgc(true)) do
    if type(o)=="table" and type(rawget(o,"getClosestNote"))=="function" and type(rawget(o,"Conductor"))=="table"
       and rawget(o,"Notes")~=nil and type(rawget(o,"Keybinds"))=="table" then return o end
  end
end
local function findEng()  -- table with goodHit/missNote/startSong
  for _,o in ipairs(getgc(true)) do
    if type(o)=="table" and type(rawget(o,"goodHit"))=="function" and type(rawget(o,"missNote"))=="function"
       and type(rawget(o,"startSong"))=="function" then return o end
  end
end
local function findHandlers()  -- onKeyDown, onKeyUp by constants
  local kd,ku
  for _,f in ipairs(getgc()) do
    if type(f)=="function" then
      local ok,cs=pcall(getc,f)
      if ok then
        local gcn,good,nKU,strums=false,false,false,false
        for _,c in ipairs(cs) do
          if c=="getClosestNote" then gcn=true elseif c=="goodHit" then good=true
          elseif c=="onKeyUp" then nKU=true elseif c=="Strums" then strums=true end
        end
        if gcn and good and not kd then kd=f end
        if nKU and strums and not gcn and not ku then ku=f end
      end
    end
  end
  return kd,ku
end
local function findHeld(kd,ku)  -- shared small dir-bool upvalue
  if not (kd and ku) then return end
  local set={}; for _,u in ipairs(getu(ku)) do if type(u)=="table" then set[u]=true end end
  for _,u in ipairs(getu(kd)) do
    if type(u)=="table" and set[u] then
      local n=0; local ok=true
      for k,v in pairs(u) do n=n+1; if not (type(k)=="string" and type(v)=="boolean") then ok=false break end end
      if ok and n<=12 then return u end
    end
  end
end

local E   = findEngine()
local eng = findEng()
local kd, ku = findHandlers()
local heldState = findHeld(kd, ku)
g.__AE=E
if not (E and eng and ku and heldState) then
  warn("[Afternight] หาไม่ครบ — เข้าเพลง/เมนูแล้วรันใหม่  (E="..tostring(E~=nil).." eng="..tostring(eng~=nil)..")")
end
local goodHit = eng and eng.goodHit

----------------------------------------------------- missNote-block (false-miss +330)
local function noteFrom(...) for i=1,select("#",...) do local a=select(i,...); if type(a)=="table" and (a.strumTime~=nil or a.dir~=nil) then return a end end end
if eng then
  if g.__ANmnRestore then pcall(g.__ANmnRestore) end
  local mn=eng.missNote
  local o; o=hookfn(mn, function(...) local nt=noteFrom(...); if nt and (nt.hit or nt.wasHit) and not nt.missed then return end; return o(...) end)
  g.__ANmnRestore=function() hookfn(mn,o) end
end

----------------------------------------------------- autoplay
g.__ANON       = (g.__ANON==nil) and true or g.__ANON
g.__ANsusbuf   = g.__ANsusbuf   or 8     -- ปล่อย hold หลัง tick สุดท้าย (ms)
g.__ANreceptor = (g.__ANreceptor==nil) and true or g.__ANreceptor
g.__ANtapreset = g.__ANtapreset or 90    -- รีเซ็ต receptor หลัง tap (ms)
g.__ANstat = { km=0 }

local function holdEndOf(nt)
  local st=nt.sustainTimes
  if type(st)=="table" and #st>0 then return st[#st] end
  return nt.susEndTime
end
local function keymodeNow()
  local side; for _,nt in pairs(E.Notes) do if type(nt)=="table" and nt.mustPress and nt.side then side=tostring(nt.side); break end end
  local by={}; if type(E.Strums)=="table" then for _,s in pairs(E.Strums) do if type(s)=="table" then local sd=tostring(s.side); by[sd]=(by[sd] or 0)+1 end end end
  if side and by[side] then return by[side] end
  local mx=0; for _,c in pairs(by) do if c>mx then mx=c end end
  return mx>0 and mx or 4
end

local susHeld, tapReset = {}, {}
local function reset(dir) if heldState then heldState[dir]=false end; if ku then pcall(ku, dir) end end

if g.__ANAUTO then pcall(function() g.__ANAUTO:Disconnect() end) end
g.__ANAUTO = RunService.Heartbeat:Connect(function()
  if not (type(E)=="table" and type(E.Conductor)=="table" and goodHit) then
    E=findEngine(); g.__AE=E
    if not E then return end
  end
  if sti then pcall(sti, 2) end
  if not g.__ANON then
    for d in pairs(susHeld) do reset(d); susHeld[d]=nil end
    for d in pairs(tapReset) do reset(d); tapReset[d]=nil end
    return
  end
  local now=E.Conductor.SongPosition
  if type(now)~="number" then return end
  g.__ANstat.km = keymodeNow()
  local buf=g.__ANsusbuf or 8
  local wantHold={}
  for _,nt in pairs(E.Notes) do
    if type(nt)=="table" and nt.mustPress and not nt.missed and not nt.hitCausesMiss and nt.shouldBeHitted~=false
       and type(nt.strumTime)=="number" and now>=nt.strumTime then
      local dir=nt.dir
      if nt.isSustain then
        if not nt.hit and not nt.wasHit then pcall(goodHit, nt) end
        if now <= holdEndOf(nt)+buf then wantHold[dir]=true end
      elseif not nt.hit and not nt.wasHit and now<=nt.strumTime+200 then
        pcall(goodHit, nt)
        if g.__ANreceptor and heldState and not susHeld[dir] then heldState[dir]=true; tapReset[dir]=now+(g.__ANtapreset or 90) end
      end
    end
  end
  -- sustain hold (heldState = นับ tick + ติด receptor), ปล่อยตรง tick สุดท้าย
  if heldState then
    for dir in pairs(wantHold) do if not susHeld[dir] then heldState[dir]=true; susHeld[dir]=true; tapReset[dir]=nil end end
    for dir in pairs(susHeld)  do if not wantHold[dir] then reset(dir); susHeld[dir]=nil end end
    for dir,t in pairs(tapReset) do if now>=t and not susHeld[dir] then reset(dir); tapReset[dir]=nil end end
  end
end)

