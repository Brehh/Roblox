local wow = game:GetService("ReplicatedStorage").Remotes.DataF:InvokeServer()
local curkey = wow[1].Inputs
local RunService = game:GetService('RunService')

local utf8 = {
    ['A'] = 0x41, ['B'] = 0x42, ['C'] = 0x43, ['D'] = 0x44, ['E'] = 0x45,
    ['F'] = 0x46, ['G'] = 0x47, ['H'] = 0x48, ['I'] = 0x49, ['J'] = 0x4A,
    ['K'] = 0x4B, ['L'] = 0x4C, ['M'] = 0x4D, ['N'] = 0x4E, ['O'] = 0x4F,
    ['P'] = 0x50, ['Q'] = 0x51, ['R'] = 0x52, ['S'] = 0x53, ['T'] = 0x54,
    ['SPACE'] = 0x20,
}

local function pressKey(key)
    key = string.upper(key)
    if utf8[key] then keypress(utf8[key]) end
end

local function releaseKey(key)
    key = string.upper(key)
    if utf8[key] then keyrelease(utf8[key]) end
end

if _G.bruh then
    _G.bruh:Disconnect()
    _G.bruh = nil
end

local plr = game.Players.LocalPlayer
local gui = plr.PlayerGui
local file = plr.File
local ready = file.Ready
local curside = file.CurrentPlayer
_G.on = true

local curready
local savedKey = {}
local activeNotes = {} -- Table สำหรับเก็บสถานะ Note แทนการสร้าง task.spawn

if _G.on then
    print("WORK (Optimized Version)")
    
    -- Cache ฟังก์ชันคณิตศาสตร์และตัวหนังสือเพื่อความเร็ว
    local math_abs = math.abs
    local tonumber = tonumber
    local string_match = string.match
    
    _G.bruh = RunService.Heartbeat:Connect(function()
        if not ready.Value then
            if curready then
                curready = false
                -- ปล่อยปุ่มทั้งหมดที่ค้างอยู่เมื่อจบเพลง
                for _, data in pairs(activeNotes) do
                    if data.pressed then
                        releaseKey(data.key)
                    end
                end
                savedKey = {}
                activeNotes = {}
				print("Note Ready")
            end
            return
        elseif not curready then
            curready = true
			local wowxd = game:GetService("ReplicatedStorage").Remotes.DataF:InvokeServer()
			curkey = wowxd[1].Inputs
			print("Ready Now!")
        end

        local side = string_match(curside.Value.Name, "%d+")
        local main = gui.Main.MatchFrame
        local myside = main["KeySync" .. side]

        -- 1. ค้นหาและลงทะเบียน Note ใหม่
        for _, v in ipairs(myside:GetChildren()) do
            if string.find(v.Name, "Arrow") then
                local keyIndex = tonumber(string_match(v.Name, "%d+"))
                local targetKey = curkey[keyIndex]

                for _, note in ipairs(v.Notes:GetChildren()) do
                    if note.ClassName == 'ImageLabel' and not savedKey[note] then
                        savedKey[note] = true
                        
                        -- ค้นหา Hold note แค่ "ครั้งเดียว" ตอนพบ Note แทนที่จะหาทุกเฟรม
                        local holdNote = note.Parent:FindFirstChild("Hold_"..note.Name)
                        
                        -- บันทึกลงในระบบ
                        activeNotes[note] = {
                            key = targetKey,
                            hold = holdNote,
                            pressed = false
                        }
                    end
                end
            end
        end

        -- 2. ตรวจสอบและกด Note ทั้งหมดในลูปเดียว
        for note, data in pairs(activeNotes) do
            -- ถ้า Note ถูกเกมทำลายไปแล้ว ให้ปล่อยปุ่มและลบออกจากระบบ
            if (not note.Parent) and ((not data.hold) or (not data.hold.Parent)) then
                if data.pressed then releaseKey(data.key) end
                activeNotes[note] = nil
                continue
            end

            -- จัดการจังหวะกด
            if not data.pressed then
                if note.Position.Y.Scale >= 0.05 then
                    pressKey(data.key)
                    data.pressed = true
                    
                    -- ถ้าไม่ใช่ปุ่ม Hold ให้ปล่อยทันที (จำลองการทำงานเดิม)
                    if not data.hold then
                        releaseKey(data.key)
                        activeNotes[note] = nil
                    end
                end
            -- จัดการจังหวะปล่อย (สำหรับปุ่ม Hold)
            else
                local hold = data.hold
                if hold then
                    if hold.Position.Y.Scale >= math_abs(hold.Size.Y.Scale) then
                        releaseKey(data.key)
                        activeNotes[note] = nil
                    end
                end
            end
        end
    end)
end
