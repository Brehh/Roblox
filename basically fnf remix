local wow = game:GetService("ReplicatedStorage").Remotes.DataF:InvokeServer()
local curkey = wow[1].Inputs
local RunService = game:GetService('RunService')
local UserInputService = game:GetService("UserInputService")
local ENUM_ALIASES = {}

-- 1. Grab every single Enum category in Roblox
for _, enumItem in ipairs(Enum.KeyCode:GetEnumItems()) do
    local name = string.upper(enumItem.Name)
    local success, character = pcall(function()
        return UserInputService:GetStringForKeyCode(enumItem)
    end)
    
    if success and character and character ~= "" then
        local upperChar = string.upper(character)
        ENUM_ALIASES[name] = utf8.codepoint(upperChar)
    end
end

-- Custom fallback function
local function getByteValue(input)
    local lookupKey = string.upper(input)
    if ENUM_ALIASES[lookupKey] then
        return ENUM_ALIASES[lookupKey]
    end
    local success, codePoint = pcall(utf8.codepoint, input)
    return success and codePoint or nil
end

local function pressKey(key)
    local truekey = getByteValue(key)
    if truekey then keypress(truekey) end
end

local function releaseKey(key)
    local truekey = getByteValue(key)
    if truekey then keyrelease(truekey) end
end

if _G.bruh then
    _G.bruh:Disconnect()
    _G.bruh = nil
end

local plr = game.Players.LocalPlayer
local gui = plr.PlayerGui
local file = plr.File
local ready = file.Ready
local curside = file.CurrentPlayer

local side
local main
local myside
_G.on = false

local curready
local activeNotes = {}
local noteConnections = {} -- เก็บ Event เพื่อลบทิ้งตอนจบเพลง

if _G.on then
    print("WORK (Max Performance + Hold Fix)")
    
    local math_abs = math.abs
    local tonumber = tonumber
    local string_match = string.match
    
    _G.bruh = RunService.RenderStepped:Connect(function()
        if not ready.Value then
            if curready then
                curready = false
                
                for _, conn in ipairs(noteConnections) do
                    conn:Disconnect()
                end
                noteConnections = {}
                
                for _, data in pairs(activeNotes) do
                    if data.pressed then
                        releaseKey(data.key)
                    end
                end
                activeNotes = {}
                print("Note Ready")
            end
            return
            
        elseif not curready then
            curready = true
            side = string_match(curside.Value.Name, "%d+")
            main = gui.Main.MatchFrame
            myside = main["KeySync" .. side]
            
            local wowxd = game:GetService("ReplicatedStorage").Remotes.DataF:InvokeServer()
            curkey = wowxd[1].Inputs
            
            for _, v in ipairs(myside:GetChildren()) do
                if string.find(v.Name, "Arrow") then
                    local keyIndex = tonumber(string_match(v.Name, "%d+"))
                    local targetKey = curkey[keyIndex]
                    local notesFolder = v:WaitForChild("Notes")
                    
                    local function registerNote(note)
                        -- กรณี ImageLabel (Note หลัก) โหลดเข้าโฟลเดอร์
                        if note.ClassName == 'ImageLabel' then
                            if not activeNotes[note] then
                                -- ลองหา Hold เผื่อมันเกิดมาก่อนหน้าแล้ว
                                local holdNote = note.Parent:FindFirstChild("Hold_"..note.Name)
                                activeNotes[note] = {
                                    key = targetKey,
                                    hold = holdNote,
                                    pressed = false
                                }
                            end
                            
                        -- กรณี Frame (Hold Note) โหลดเข้าโฟลเดอร์
                        elseif note.ClassName == 'Frame' and string.find(note.Name, "Hold") then
                            local notename = string_match(note.Name, "%d+")
                            if notename then
                                local mynote = note.Parent:FindFirstChild(notename)
                                if mynote then
                                    -- ถ้ามี Note หลักอยู่แล้ว อัปเดตข้อมูล Hold ให้มัน
                                    if activeNotes[mynote] then
                                        activeNotes[mynote].hold = note
                                    else
                                        -- ถ้า Hold เกิดก่อน Note หลัก ให้สร้าง Data รอไว้เลย
                                        activeNotes[mynote] = {
                                            key = targetKey,
                                            hold = note,
                                            pressed = false
                                        }
                                    end
                                end
                            end
                        end
                    end
                    
                    local conn = notesFolder.ChildAdded:Connect(registerNote)
                    table.insert(noteConnections, conn)
                    
                    for _, note in ipairs(notesFolder:GetChildren()) do
                        registerNote(note)
                    end
                end
            end
            print("Ready Now! (Event-Driven Activated)")
        end

        for note, data in pairs(activeNotes) do
            if (not note.Parent) and ((not data.hold) or (not data.hold.Parent)) then
                if data.pressed then releaseKey(data.key) end
                activeNotes[note] = nil
                continue
            end

            local y_scale = note.Position.Y.Scale

            -- จังหวะกด
            if not data.pressed then
                if y_scale >= -0.05 and y_scale <= 0.2 then
                    releaseKey(data.key)
                    pressKey(data.key)
                    activeNotes[note].pressed = true
                    
                    -- [!] ดักจับเผื่อกรณี Hold Note หลุด Event
                    if not data.hold then
                        activeNotes[note].hold = note.Parent:FindFirstChild("Hold_" .. note.Name)
                    end
                    
                    if not data.hold then
                        releaseKey(data.key)
                        activeNotes[note] = nil
                    end
                end
            -- จังหวะปล่อยปุ่ม (สำหรับ Hold)
            else
                local hold = data.hold
                if hold then
                    if hold.Parent then
                        local hold_y_scale = hold.Position.Y.Scale
                        if hold_y_scale >= math_abs(hold.Size.Y.Scale) + 0.05 then
                            releaseKey(data.key)
                            activeNotes[note] = nil
                        end
                    else
                        releaseKey(data.key)
                        activeNotes[note] = nil
                    end
                end
            end
        end
    end)
end
