local character = player.Character


local function isInZone(character,part)
	if not character or not character:FindFirstChild("HumanoidRootPart") then 
		return false 
	end

	-- Get the character's size and position
	local cframe, size = character:GetBoundingBox()

	-- Set up overlap parameters (optional, but good for filtering)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Include
	params.FilterDescendantsInstances = {character}

	-- Check if the zone part overlaps with the character
	local parts = workspace:GetPartsInPart(part, params)

	-- If the table is not empty, the player is inside
	return #parts > 0
end
local curbutton


local function coolTouch(obj)
	if obj.Name == "Rebuild" then
		if isInZone(character,obj) then
			curbutton = obj
		else
