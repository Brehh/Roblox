local dragging = false
local dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end
end)

function findPortal()
	for i,v in next, workspace:GetChildren() do
		if v:FindFirstChild("PortalHit") then
			local config = v:FindFirstChild("PortalHit").config
			local cost = config.Cost.Value
			local area = config.Area.Value
			if cost ~= "0" then
				if portals[area] and gt(portals[area].Level,cost) then
					continue
				end
				portals[area] = {Level = cost}
			elseif area == "Spawn" then
				if not portals[area] then
					portals[area] = {Level = 0}
				end
			end
		elseif v.Name == "PortalHit" then
			local config = v.config
			local cost = config.Cost.Value
			local area = config.Area.Value
			if cost ~= "0" then
				if portals[area] and gt(portals[area].Level,cost) then
					continue
				end
				portals[area] = {Level = cost}
			elseif area == "Spawn" then
				if not portals[area] then
					portals[area] = {Level = 0}
				end
			end
		end
	end
end

function getWayPoint()
	for _, waypoint in ipairs(waypointsFolder:GetChildren()) do
		if waypoint:IsA("Part") then
			if not waypoints[waypoint.Name] then
				waypoints[waypoint.Name] = waypoint
			end
			if portals[waypoint.Name] then
				if not buttons[waypoint.Name] then
					createButton(waypoint,portals[waypoint.Name].Level)
				else
					buttons[waypoint.Name].Text = waypoint.Name .. " Lvl : " .. short(portals[waypoint.Name].Level)
					buttons[waypoint.Name].LayoutOrder = portals[waypoint.Name].Level
				end
			end
		end
	end
end

function createButton(wayPoint,Level)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, -10, 0, 30)
	button.Position = UDim2.new(0, 5, 0, 0)
	button.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	button.TextColor3 = Color3.new(1, 1, 1)
	button.Text = wayPoint.Name .. " Lvl : " .. short(Level)
	button.Parent = contentFrame
	button.LayoutOrder = Level

	button.MouseButton1Click:Connect(function()
		local character = player.Character
		if character and character:FindFirstChild("HumanoidRootPart") then
			-- ปรับตำแหน่งเล็กน้อยเพื่อไม่ให้ติดพื้น
			character.HumanoidRootPart.CFrame = wayPoint.CFrame + Vector3.new(0, 5, 0)
		end
	end)
	buttons[wayPoint.Name] = button
end

