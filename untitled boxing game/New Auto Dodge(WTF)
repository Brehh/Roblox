print('Styles Loaded')

local utf8 = {
    ['A'] = 0x41, ['B'] = 0x42, ['C'] = 0x43, ['D'] = 0x44, ['E'] = 0x45,
    ['F'] = 0x46, ['G'] = 0x47, ['H'] = 0x48, ['I'] = 0x49, ['J'] = 0x4A,
    ['K'] = 0x4B, ['L'] = 0x4C, ['M'] = 0x4D, ['N'] = 0x4E, ['O'] = 0x4F,
    ['P'] = 0x50, ['Q'] = 0x51, ['R'] = 0x52, ['S'] = 0x53, ['T'] = 0x54,
    ['U'] = 0x55, ['V'] = 0x56, ['W'] = 0x57, ['X'] = 0x58, ['Y'] = 0x59,
    ['Z'] = 0x5A, ['SPACE'] = 0x20,
}

local function pressKey(key)
    key = string.upper(key)
    if utf8[key] then keypress(utf8[key]) end
end

local function releaseKey(key)
    key = string.upper(key)
    if utf8[key] then keyrelease(utf8[key]) end
end

local cachedOpp = nil
local mystyle = nil

if _G.bruh then
    _G.bruh:Disconnect()
    _G.bruh = nil
end

local currentpunch
local currentmypunch
local currentoppdash

if _G.on then
    _G.bruh = RunService.Heartbeat:Connect(function()
        if not _G.on then return end

        -- ตัด task.defer ออก เพื่อให้รันทันทีในจังหวะของ Pipeline เฟรมนั้น
        local states = Workspace:FindFirstChild('States')
        if not states then return end

        local playerState = states:FindFirstChild(LocalPlayer.Name)
        if not playerState then return end

        local occupied = playerState:FindFirstChild('Occupied')
        if not occupied then return end
		occupied.ReverseInputs.Value = false
        
        local opp = occupied.LockedOn.Value
        if not opp then 
            cachedOpp = nil 
            return 
        end

        -- Cache Style
        if cachedOpp ~= opp then
            cachedOpp = opp
            local mydata = playerState:FindFirstChild('PlayerData')
            if mydata and mydata:FindFirstChild('Style') then
                mystyle = require(style[mydata.Style.Value])
            end
        end

        if not mystyle then return end

        local myCharacter = LocalPlayer.Character
        local myRoot = myCharacter and myCharacter:FindFirstChild('HumanoidRootPart')
        local oppRoot = opp:FindFirstChild('HumanoidRootPart')
        
        local liveFolder = Workspace:FindFirstChild('Live')
        local opplive = liveFolder and liveFolder:FindFirstChild(opp.Name)

        if not (oppRoot and myRoot and opplive) then return end

        -- เช็ค Stamina แค่ตอนที่มีเป้าหมายและองค์ประกอบครบ
        local charData = playerState:FindFirstChild('CharacterData')
        local stamina = charData and charData.Stamina.Value or 0

        -- ดึงค่าพื้นฐานที่จำเป็นก่อน (Lazy evaluation)
        local currentID = opplive:GetAttribute("PreviousPunching")
        local isheavy = opplive:GetAttribute("IsHeavy")
        local currentP = opplive:GetAttribute("CurrentPunch")
		local landtime = opplive:GetAttribute("LandTime")
		local perfect = myCharacter:GetAttribute("Perfect")
		
        -- Logic สำหรับหลบ (Dodge)
        if currentID and ((not currentpunch) or (currentID > currentpunch)) and (currentP == 1 or isheavy) then
            
            local punching = opplive:GetAttribute("Punching")
            if not landtime then
				if _G.lasttask then
					task.cancel(_G.lasttask)
					_G.lasttask = nil
				end
			end
            if (landtime or perfect) and punching then
                local bruhtime = (landtime - currentID) >= 0.5
                local ohnumm = (isheavy or bruhtime) and 0 or 0.052
				local oppSide = opplive:GetAttribute("AttackingHand")
                local dodgeKey = (oppSide == "LeftHand") and "D" or "A"
				local meCanPunch = occupied.CanPunch.Value
				local meStun = occupied.Stunned.Value
				currentpunch = currentID
				local curtime = landtime or perfect
				local distance = (myRoot.Position - oppRoot.Position).Magnitude
				local oppdash = opplive:GetAttribute("AttackingHand")
				
				if _G.lasttask then
					task.cancel(_G.lasttask)
					_G.lasttask = nil
				end
				
				if charData.UltimateEnergy.Value == 100 or ohnumm ~= 0 or not meCanPunch or meStun or distance >= 7 or occupied.Blocking.Value then
					_G.lasttask = task.delay(curtime + ohnumm - workspace:GetServerTimeNow(),function ()
						local distance = (myRoot.Position - oppRoot.Position).Magnitude
						
						if distance <= 8 and stamina >= 30 then
							print("Yeah")
							-- แยกรัน Thread กดปุ่ม เพื่อไม่ให้บล็อกเฟรมเรท
							local dashTime = mystyle.DashInfo.DefaultInfo.DashTime
							task.spawn(function()
									releaseKey('W')
									releaseKey('S')
									releaseKey('A')
									releaseKey('D')
									pressKey('W')
									pressKey(dodgeKey)
									pressKey("SPACE")
									releaseKey("SPACE")
									task.wait(dashTime)
									releaseKey('W')
									task.wait(0.3)
									releaseKey(dodgeKey)
							end)
						end
					end)
				else
					local distance = (myRoot.Position - oppRoot.Position).Magnitude
					if distance <= 7 and stamina >= 30 then
						mouse1click()
					end
				end
            end
        end

        -- Logic สำหรับโจมตีสวน (Parry/Attack)
        local mypunchID = myCharacter:GetAttribute("Punching")
        local isdash = workspace.States[opp.Name].CharacterData.Dashing.Value
		local mylandtime = myCharacter:GetAttribute("LandTime")
		local oppdash = opplive:GetAttribute("DashInvulnerable")
		local oppdashclear = opplive:GetAttribute("DashClearTime")
		local oppdashtime = opplive:GetAttribute("DashClearTime")
		local oppdashpos = opplive:GetAttribute("CachedDashPosition")
		local oppdashvelo = opplive:GetAttribute("CachedDashVelocity")
		local totaloppdash = stringToVector3(oppdashpos) + stringToVector3(oppdashvelo)
        if mypunchID and isdash and ((not currentmypunch) or (mypunchID > currentmypunch)) and (currentP == 1 or isheavy) then
            if mylandtime and oppdash then
                local isMyHeavy = myCharacter:GetAttribute("IsHeavy")
                local ohnumm = isMyHeavy and 0 or 0.05
				myCharacter:SetAttribute("TimeForFeint",myCharacter:GetAttribute("TimeForFeint")+1)
				local tff = myCharacter:GetAttribute("TimeForFeint")
				
                if oppdash then
                    local distance = (myRoot.Position - oppRoot.Position).Magnitude
                    
                    if distance <= 8 and stamina >= 30 then
                        currentmypunch = mypunchID
                        if isMyHeavy then
							print("Small")
                            mouse1click()
                        else
							print(tff-tick())
                            mouse2click()
                        end
                    end
                end 
            end
		elseif isdash and not mylandtime then
			if currentoppdash ~= oppdash then
				print("PUNCNH")
				currentoppdash = oppdash
				task.delay(oppdashclear-workspace:GetServerTimeNow(),function ()
					local distance = (myRoot.Position - totaloppdash).Magnitude
					print(distance)
					if distance <= 7 and stamina >= 30 then
						mouse1click()
						local mypunchID = myCharacter:GetAttribute("Punching")
						currentmypunch = mypunchID
					end
				end)
			end
        end
    end)
end
