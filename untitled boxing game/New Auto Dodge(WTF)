local function buildCheckTable(oppstyle)
    cachedCheck = {}
    
    -- Combos
    for _, v in next, oppstyle.Combos do
        local j = v[1]
		local speed = j.AnimSpeed
        local bruh = j.TrailInfo.TargetPart
        local uh = (bruh == 'RightHand') and 'Left' or 'Right'
        local cool = (bruh == 'RightHand') and 'A' or 'D'
        cachedCheck[j.AnimId] = {0, uh, cool }
    end
    
    -- Heavy Attacks
    local heavy = oppstyle.HeavyAttacks.DefaultPunchInfo.MoveDelay
    for i, v in next, oppstyle.HeavyAttacks do
        if type(i) == 'number' then
			local ohtime = v.LandedFrame
            local bruh = v.TrailInfo.TargetPart
            local uh = (bruh == 'RightHand') and 'Left' or 'Right'
            local cool = (bruh == 'RightHand') and 'A' or 'D'
            cachedCheck[v.AnimId] = { 0, uh, cool }
        end
    end
    
    -- Ultimate
    local ulti = oppstyle.UltimateInfo.DefaultPunchInfo.Startup
    for i, v in next, oppstyle.UltimateInfo do
        if type(i) == 'number' then
            local bruh = v.TrailInfo.TargetPart
            local uh = (bruh == 'RightHand') and 'Left' or 'Right'
            local cool = (bruh == 'RightHand') and 'A' or 'D'
            cachedCheck[v.AnimId] = { 0, uh, cool }
        end
    end
end

