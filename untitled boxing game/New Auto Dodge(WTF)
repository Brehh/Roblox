local LocalPlayer = Players.LocalPlayer

local function stringToVector3(str: string): Vector3
    -- Split the string by commas into an array
    local components = string.split(str, ",") 
    
    -- Convert the values to numbers and unpack them into Vector3.new
    return Vector3.new(
        tonumber(components[1]), 
        tonumber(components[2]), 
        tonumber(components[3])
    )
end

-- โหลด Styles
