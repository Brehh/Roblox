_G.on = true -- เปลี่ยนเป็น true เมื่อต้องการเปิดใช้งาน

local gamesettings = require(game:GetService("ReplicatedStorage").Modules.Styles.GameplaySettings)
local RunService = game:GetService('RunService')
local Workspace = game:GetService('Workspace')
local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local ContextActionService = game:GetService("ContextActionService")

local LocalPlayer = Players.LocalPlayer

-- ป้องกัน Error ดักค่า nil ก่อนนำไป split
local function stringToVector3(str)
    if not str or type(str) ~= "string" then return Vector3.zero end
    local components = string.split(str, ",") 
    if #components >= 3 then
        return Vector3.new(tonumber(components[1]), tonumber(components[2]), tonumber(components[3]))
    end
    return Vector3.zero
end

-- ฟังก์ชันสำหรับดูดซับเมาส์
local function sinkMouseInput()
    return Enum.ContextActionResult.Sink
end

-- โหลด Styles
local style = {}
for _, v in next, ReplicatedStorage.Modules.Styles:GetDescendants() do
    if v:IsA('ModuleScript') then
        style[v.Name] = v
    end
end
print('Styles Loaded')

local utf8 = {
    ['A'] = 0x41, ['B'] = 0x42, ['C'] = 0x43, ['D'] = 0x44, ['E'] = 0x45,
    ['F'] = 0x46, ['G'] = 0x47, ['H'] = 0x48, ['I'] = 0x49, ['J'] = 0x4A,
    ['K'] = 0x4B, ['L'] = 0x4C, ['M'] = 0x4D, ['N'] = 0x4E, ['O'] = 0x4F,
    ['P'] = 0x50, ['Q'] = 0x51, ['R'] = 0x52, ['S'] = 0x53, ['T'] = 0x54,
    ['SPACE'] = 0x20,
}

local function pressKey(key)
    key = string.upper(key)
    if utf8[key] then keypress(utf8[key]) end
end

local function releaseKey(key)
    key = string.upper(key)
    if utf8[key] then keyrelease(utf8[key]) end
end

local cachedOpp = nil
local mystyle = nil
local currentpunch = 0
local currentmypunch = 0
local currentoppdash = nil

if _G.bruh then
    _G.bruh:Disconnect()
    _G.bruh = nil
end

if _G.on then
    _G.bruh = RunService.Heartbeat:Connect(function()
        if not _G.on then return end

        local states = Workspace:FindFirstChild('States')
        local playerState = states and states:FindFirstChild(LocalPlayer.Name)
        local occupied = playerState and playerState:FindFirstChild('Occupied')
        
        if not occupied then return end
        occupied.ReverseInputs.Value = false
        
        local opp = occupied.LockedOn.Value
        if not opp then 
            cachedOpp = nil 
            -- ปลดเมาส์เสมอเมื่อหลุดเป้าหมาย
            ContextActionService:UnbindAction("BlockMouseClicks")
            return 
        end

        -- Cache Style
        if cachedOpp ~= opp then
            cachedOpp = opp
            local mydata = playerState:FindFirstChild('PlayerData')
            if mydata and mydata:FindFirstChild('Style') then
                mystyle = require(style[mydata.Style.Value])
            end
        end

        if not mystyle then return end

        local myCharacter = LocalPlayer.Character
        local myRoot = myCharacter and myCharacter:FindFirstChild('HumanoidRootPart')
        local oppRoot = opp:FindFirstChild('HumanoidRootPart')
        local liveFolder = Workspace:FindFirstChild('Live')
        local opplive = liveFolder and liveFolder:FindFirstChild(opp.Name)

        if not (oppRoot and myRoot and opplive) then return end

        local charData = playerState:FindFirstChild('CharacterData')
        local stamina = charData and charData.Stamina.Value or 0

        local currentID = opplive:GetAttribute("PreviousPunching") or 0
        local isheavy = opplive:GetAttribute("IsHeavy") or false
        local currentP = opplive:GetAttribute("CurrentPunch") or 0
        local landtime = opplive:GetAttribute("LandTime")
        local perfect = myCharacter:GetAttribute("Perfect")
        local tryattack = opplive:GetAttribute("TryAttack")
		
        
        -- แก้ Logic การตรวจสอบ ID ให้ปลอดภัยจากการ Error
        local isNewAttack = currentID > currentpunch
        local validPunchType = (currentP == 1 or isheavy)
        
        -- Logic สำหรับหลบ (Dodge)
        if (currentID > 0) and isNewAttack and validPunchType then
            local punching = opplive:GetAttribute("Punching")
            
            if not (landtime or perfect) then
                if _G.lasttask then
                    task.cancel(_G.lasttask)
                    _G.lasttask = nil
                    ContextActionService:UnbindAction("BlockMouseClicks")
                end
				if _G.dodge then
					task.cancel(_G.dodge)
                    _G.dodge = nil
                    ContextActionService:UnbindAction("BlockMouseClicks")
				end
            end
            
            if (landtime or perfect) and (punching or tryattack) then
                local bruhtime = (landtime and currentID and (landtime - currentID) >= 0.5) or false
                local ohnumm = (isheavy or bruhtime) and 0 or 0.052
                local oppSide = opplive:GetAttribute("AttackingHand")
                local dodgeKey = (oppSide == "LeftHand") and "D" or "A"
                
                local meCanPunch = occupied.CanPunch.Value
                local meStun = occupied.Stunned.Value
                local curtime = landtime or perfect
                local distance = (myRoot.Position - oppRoot.Position).Magnitude
                
                if _G.lasttask then
                    task.cancel(_G.lasttask)
                    _G.lasttask = nil
                    ContextActionService:UnbindAction("BlockMouseClicks")
                end

				if _G.dodge then
					task.cancel(_G.dodge)
                    _G.dodge = nil
                    ContextActionService:UnbindAction("BlockMouseClicks")
				end
                
                if charData.UltimateEnergy.Value == 100 or ohnumm ~= 0 or not meCanPunch or meStun or distance >= 7 or charData.Blocking.Value or ((landtime or perfect) - workspace:GetServerTimeNow()) <= 0.2  then
                    currentpunch = currentID
                    
                    ContextActionService:BindActionAtPriority(
                        "BlockMouseClicks", sinkMouseInput, false,
                        Enum.ContextActionPriority.High.Value + 10,
                        Enum.UserInputType.MouseButton1, Enum.UserInputType.MouseButton2
                    )
                    
                    -- *การอัพเกรด*: ถ้าถึงเวลาแล้ว ให้ทำงานทันที ไม่ต้อง delay ให้เสียเฟรมเรท
                    local targetTime = curtime + ohnumm
                    local waitTime = targetTime - workspace:GetServerTimeNow()
                    
                    local function executeDodge()
                        local dist = (myRoot.Position - oppRoot.Position).Magnitude
                        if dist <= 8 and stamina >= 30 then
                            local dashTime = mystyle.DashInfo.DefaultInfo.DashTime
                            _G.dodge = task.spawn(function()
                                releaseKey('W'); releaseKey('S'); releaseKey('A'); releaseKey('D')
                                pressKey('W'); pressKey(dodgeKey)
                                pressKey("SPACE"); releaseKey("SPACE")
                                task.wait(dashTime)
                                releaseKey('W')
                                task.wait(0.3)
                                releaseKey(dodgeKey)
                            end)
                        end
                        ContextActionService:UnbindAction("BlockMouseClicks")
                    end

                    if waitTime <= 0 then
                        task.spawn(executeDodge)
                    else
                        _G.lasttask = task.delay(waitTime, executeDodge)
                    end
                else
                    if distance <= 7 and stamina >= 30 then
                        currentpunch = currentID
                        mouse1click()
                    end
                end
            end
        end

        -- Logic สำหรับโจมตีสวน (Parry/Attack)
        local mypunchID = myCharacter:GetAttribute("Punching")
        local isdash = workspace.States[opp.Name].CharacterData.Dashing.Value
        local mylandtime = myCharacter:GetAttribute("LandTime")
        local oppdash = opplive:GetAttribute("DashInvulnerable")
        
        if mypunchID and isdash and (mypunchID > currentmypunch) and validPunchType then
            if mylandtime and oppdash then
                local isMyHeavy = myCharacter:GetAttribute("IsHeavy")
                
                -- เอาการตั้งค่า TimeForFeint รัวๆ ออก เพราะมันทำให้สคริปต์ทำงานซ้ำซ้อน
                local distance = (myRoot.Position - oppRoot.Position).Magnitude
                
                if distance <= 8 and stamina >= 30 then
                    currentmypunch = mypunchID
                    if isMyHeavy then
                        mouse1click()
                    else
                        mouse2click()
                    end
                end 
            end
        elseif isdash and not mylandtime then
            local oppdashpos = opplive:GetAttribute("CachedDashPosition")
            local oppdashvelo = opplive:GetAttribute("CachedDashVelocity")
            local oppdashclear = opplive:GetAttribute("DashClearTime")
            
            -- คลาส stringToVector3 ตอนนี้ป้องกันค่า nil แล้ว ทำให้โค้ดไม่พัง
            local totaloppdash = stringToVector3(oppdashpos) + stringToVector3(oppdashvelo)
            
            if currentoppdash ~= oppdash and oppdashclear then
                currentoppdash = oppdash
                
                local waitTime = oppdashclear - workspace:GetServerTimeNow()
                
                local function executeDashAttack()
                    local distance = (myRoot.Position - totaloppdash).Magnitude
                    if distance <= 7 and stamina >= 30 then
                        mouse1click()
                        currentmypunch = myCharacter:GetAttribute("Punching") or currentmypunch
                        if _G.lasttask then
                            task.cancel(_G.lasttask)
                            _G.lasttask = nil
                            ContextActionService:UnbindAction("BlockMouseClicks")
                        end
						if _G.dodge then
							task.cancel(_G.dodge)
							_G.dodge = nil
							ContextActionService:UnbindAction("BlockMouseClicks")
						end
                    end
                end

                if waitTime <= 0 then
                    task.spawn(executeDashAttack)
                else
                    task.delay(waitTime, executeDashAttack)
                end
            end
        end
    end)
end
