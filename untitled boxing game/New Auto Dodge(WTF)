_G.on = true -- เปลี่ยนเป็น true เมื่อต้องการเปิดใช้งาน

local gamesettings = require(game:GetService("ReplicatedStorage").Modules.Styles.GameplaySettings)
local RunService = game:GetService('RunService')
local Workspace = game:GetService('Workspace')
local Players = game:GetService('Players')
